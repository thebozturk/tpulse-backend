# Environment
NODE_ENV=development
PORT=8080

# Database (PostgreSQL 16 — greenfield, Faz 1'de schema/migration)
DATABASE_URL=postgresql://tpulse:tpulse_dev@localhost:5432/transferpulse

# JWT (≥32 karakter — kullanıcı doldurur)
JWT_SECRET=

# Redis (idempotency, cache, ileride BullMQ)
REDIS_CONNECTION_STRING=redis://localhost:6379

# CORS (virgülle ayrılmış whitelist)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Swagger UI (/swagger)
ENABLE_SWAGGER=true

# --- İleride dolacak entegrasyonlar (Faz 4/7/2) ---
# Cloudflare R2 (görsel storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Google OAuth (login)
GOOGLE_AUTH_CLIENT_ID=

# API-Football (senkron — boşsa senkron pasif)
API_FOOTBALL_KEY=

# SMTP (şifre sıfırlama — boşsa link log'a yazılır)
SMTP_HOST=
SMTP_USERNAME=
SMTP_PASSWORD=
