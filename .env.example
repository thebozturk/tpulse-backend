# Environment
NODE_ENV=development
PORT=8080

# Database (PostgreSQL 16 — greenfield, Faz 1'de schema/migration)
DATABASE_URL=postgresql://tpulse:tpulse_dev@localhost:5432/transferpulse

# JWT (≥32 karakter — kullanıcı doldurur)
JWT_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_ISSUER=TransferPulse
JWT_AUDIENCE=TransferPulseApp
JWT_REFRESH_EXPIRY_DAYS=90

# Şifre sıfırlama
# Prod: https://transferpulse.app/reset-password (Universal/App Link → mobil app,
# app yoksa web fallback sayfası). Backend ?email=&token= ekler.
PASSWORD_RESET_TOKEN_MINUTES=60
PASSWORD_RESET_URL_BASE=http://localhost:3000/reset-password

# E-posta doğrulama
# Prod: https://transferpulse.app/verify-email (Universal/App Link). App kuruluysa
# açılır ve POST /api/auth/verify-email çağırır; değilse web fallback aynı ucu çağırır.
EMAIL_VERIFY_TOKEN_MINUTES=1440
EMAIL_VERIFY_URL_BASE=http://localhost:3000/verify-email

# E-posta digest job'ları (cron 6 alan: sec min hour dom mon dow)
# Güvenlik için varsayılan kapalı — prod'da true yap.
DIGEST_ENABLED=false
DIGEST_WEEKLY_CRON=0 0 9 * * 1
DIGEST_TRANSFER_ALERT_CRON=0 0 18 * * *

# Redis (idempotency, cache, ileride BullMQ)
REDIS_CONNECTION_STRING=redis://localhost:6379

# Idempotency (Idempotency-Key header TTL — saniye, default 600 = 10dk)
IDEMPOTENCY_TTL_SECONDS=600

# OpenTelemetry (endpoint BOŞ ise telemetry tamamen kapalı — no-op)
OTEL_EXPORTER_OTLP_ENDPOINT=          # örn. http://localhost:4318
OTEL_SERVICE_NAME=TransferPulse.Api
# OTEL_EXPORTER_OTLP_HEADERS=          # örn. authorization=Bearer xxx (opsiyonel)

# CORS (virgülle ayrılmış whitelist)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Swagger UI (/swagger)
ENABLE_SWAGGER=true

# --- İleride dolacak entegrasyonlar (Faz 4/7/2) ---
# Storage — AWS S3 (prod) / MinIO (lokal). Cloudflare R2 KULLANILMIYOR.
S3_ENDPOINT=                  # MinIO: http://localhost:9000 — AWS'de boş bırak
S3_REGION=us-east-1
S3_BUCKET=transferpulse
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=           # örn http://localhost:9000/transferpulse
S3_FORCE_PATH_STYLE=true      # MinIO: true, AWS: false

# Google OAuth (login)
GOOGLE_AUTH_CLIENT_ID=

# API-Football (api-sports.io v3 — senkron; boşsa canlı senkron pasif)
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_LEAGUE_IDS=39,140,135,78,61
API_FOOTBALL_SEASON=2024
SYNC_CRON=                     # boşsa cron yok; örn "0 0 3 * * *" (her gün 03:00)
DETECT_TRANSFERS=false
MIRROR_IMAGES=false

# Resend (e-posta gönderimi) — RESEND_API_KEY boşsa e-posta gönderilmez, log'a yazılır.
# From adresi Resend'de doğrulanmış domain olmalı.
RESEND_API_KEY=
EMAIL_FROM=TransferPulse <no-reply@transferpulse.app>

# E-posta görselleri (logo) absolute base URL. Şimdilik API public/'ten serve eder.
# Prod: https://<API_DOMAIN>/public  ·  S3'e geçince: S3_PUBLIC_BASE_URL ile değiştir.
EMAIL_ASSET_BASE_URL=http://localhost:8080/public

# Frontend kök URL'i — e-postalardaki CTA / abonelikten çıkma linkleri.
# Prod: https://transferpulse.app (Universal/App Link; unsubscribe → /abonelik/cik,
# app yoksa web fallback).
APP_WEB_URL=http://localhost:3000

# Bot ingestion — API key SHA-256 hex hash (düz key SAKLAMA). Üretmek için:
#   node -e "console.log(require('crypto').createHash('sha256').update('<API_KEY>').digest('hex'))"
BOT_API_KEY_HASH=

# Yük testi (k6) — true ise rate limit (ThrottlerGuard) BYPASS edilir.
# SADECE non-prod; production'da true → boot fail (env validation engeller).
# Lokal yük testi: docker-compose.loadtest.yml overlay'i bunu otomatik true yapar.
LOAD_TEST_MODE=false

# Feed ("Senin İçin") skorlama parametreleri — hepsi opsiyonel (default'lu).
# hotScore = (w_like·like + w_vote·(agree+disagree) + w_comment·comment) / (ageHours+2)^gravity
FEED_W_LIKE=1
FEED_W_VOTE=0.5
FEED_W_COMMENT=2
FEED_GRAVITY=1.5
# In-network yakınlık çarpanları (takip > favori konu).
FEED_AFFINITY_FAVOURITE=1.3
FEED_AFFINITY_FOLLOW=1.5
# Kaynak başına aday limiti + sıralı sonuç havuzu kapağı.
FEED_SOURCE_LIMIT=200
FEED_MAX_RESULTS=200
